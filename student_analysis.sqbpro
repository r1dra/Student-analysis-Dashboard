-- ADD COLUMNS (FRESH DB ONLY)
-- ==============================

ALTER TABLE students_final ADD COLUMN overall_rank INTEGER;
ALTER TABLE students_final ADD COLUMN gender_rank INTEGER;
ALTER TABLE students_final ADD COLUMN math_rank INTEGER;
ALTER TABLE students_final ADD COLUMN performance_cluster TEXT;

-- ==============================
-- RANKING LOGIC
-- ==============================

UPDATE students_final
SET overall_rank = (
    SELECT COUNT(*) + 1
    FROM students_final s2
    WHERE s2.avg_score &gt; students_final.avg_score
);

UPDATE students_final
SET gender_rank = (
    SELECT COUNT(*) + 1
    FROM students_final s2
    WHERE s2.gender = students_final.gender
    AND s2.avg_score &gt; students_final.avg_score
);

UPDATE students_final
SET math_rank = (
    SELECT COUNT(*) + 1
    FROM students_final s2
    WHERE s2.math_score &gt; students_final.math_score
);

-- ==============================
-- CLUSTERING
-- ==============================

UPDATE students_final
SET performance_cluster =
    CASE
        WHEN avg_score &gt;= 80 THEN 'High Achiever'
        WHEN avg_score &gt;= 60 THEN 'Average Student'
        ELSE 'Needs Improvement'
    END;</sql><current_tab id="0"/></tab_sql></sqlb_project>
